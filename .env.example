# ── Copy to .env and fill in values ──────────────────────────────────────────

# LLM (choose one)
GROQ_API_KEY=your_groq_api_key_here
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# Servers
API_PORT=8000
GRADIO_PORT=7860

# Data directory (defaults to ./data)
# DATA_DIR=/path/to/persistent/storage

# MLOps thresholds
DRIFT_SHARPE_THRESHOLD=0.15     # retrain if Sharpe drops > 15 %
DRIFT_RETURN_THRESHOLD=0.10     # retrain if expected return drops > 10 %
MONITORING_WINDOW_DAYS=30       # rolling window for drift detection
